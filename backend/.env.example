# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_KEY=your_supabase_anon_key

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development

# =============================================================================
# Twitter/X via twikit (free unofficial API)
# =============================================================================
TWITTER_USERNAME=your_twitter_username
TWITTER_EMAIL=your_twitter_email
TWITTER_PASSWORD=your_twitter_password

# =============================================================================
# Facebook Graph API (Phase 2)
# Requires: Meta Developer App with pages_read_engagement permission
# Get token at: https://developers.facebook.com/tools/explorer/
# =============================================================================
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
FACEBOOK_PAGE_IDS=MOHKenya,WHOKenya,UNICEFKenya

# =============================================================================
# Grok xAI — live X/web search + AI classification (Phase 2)
# Get API key at: https://console.x.ai (free $25 credits on signup)
# =============================================================================
XAI_API_KEY=your_xai_api_key
XAI_MODEL=grok-3-mini

# =============================================================================
# Social Media Harvest Mode: "live", "mock", or "hybrid"
# live    = only real data (errors if APIs unavailable)
# mock    = only mock/simulated data (no API calls)
# hybrid  = try real first, fallback to mock (recommended)
# =============================================================================
SOCIAL_HARVEST_MODE=hybrid
